{
  "name": "rva-server",
  "version": "1.0.50",
  "scripts": {
    "db": "bun run generate && bun run migrate",
    "generate": "bunx drizzle-kit generate --dialect sqlite --schema ./src/db/schema/index.ts",
    "migrate": "bun run ./scripts/migrate.ts",
    "dev": "bun run --watch src/main.ts"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@types/jsonwebtoken": "^9.0.10",
    "drizzle-orm": "^0.45.1",
    "elysia": "latest",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.7"
  },
  "devDependencies": {
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "module": "src/index.js"
}
